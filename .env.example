# ─────────────────────────────────────────────────────────────
# Supabase  (server-only — NEVER prefix any of these with NEXT_PUBLIC_)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Project Settings → API → "service_role" secret. Server-only. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Private storage bucket that holds the photos
SUPABASE_PHOTOS_BUCKET=journal-photos

# ─────────────────────────────────────────────────────────────
# Telegram bot
# ─────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Shared secret Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token header.
# Generate one with:  openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
# Comma-separated Telegram chat IDs allowed to add memories (yours).
# Leave blank during first setup — the bot will tell you your chat id.
TELEGRAM_ALLOWED_CHAT_IDS=
# Optional: the bot's @username (with or without @). Only used to show an
# "Add a memory" link on the book that opens the bot. Safe to leave blank.
JOURNAL_BOT_USERNAME=

# ─────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────
# Public URL of the deployed book (used in the bot's success message & absolute links)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# Optional: gate the whole site behind a login page with this password. Blank = open.
SITE_PASSWORD=
# Cover text for the FIRST (default) journal. Create more books from the bot
# with /newjournal — each gets its own title, subtitle, and /j/<slug> page.
JOURNAL_TITLE=Our Journal
JOURNAL_SUBTITLE=A book of moments
# Timezone used for /today in the bot and for date display
JOURNAL_TIMEZONE=Asia/Singapore
